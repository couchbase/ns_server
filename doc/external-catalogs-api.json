{
  "openapi": "3.1.1",
  "info": {
    "title": "Couchbase External Catalogs API",
    "description": "REST API for managing external catalogs in Couchbase Server. External catalogs are identified by a unique name.\n",
    "version": "1.0.0",
    "license": {
      "name": "Business Source License 1.1",
      "url": "https://www.couchbase.com/licensing"
    }
  },
  "paths": {
    "/pools/default/externalCatalogs": {
      "get": {
        "summary": "List all external catalogs",
        "operationId": "getExternalCatalogs",
        "tags": [
          "External Catalogs"
        ],
        "security": [
          {
            "basicAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "A JSON object containing the manifest uid and external catalogs keyed by name.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CatalogList"
                },
                "example": {
                  "uid": 2,
                  "my-catalog": {
                    "rev": 1
                  },
                  "other-catalog": {
                    "rev": 2
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      },
      "put": {
        "summary": "Set the entire external catalog manifest",
        "operationId": "setExternalCatalogManifest",
        "description": "Atomically replaces all external catalogs with the provided set. Each catalog in the request body is validated against the query service; the manifest is only applied if all catalogs are valid. The manifest uid is set by the server and cannot be supplied in the request body. The optional `validOnUid` query parameter provides compare-and-swap semantics: the manifest is replaced only if its current uid matches the supplied value.\n",
        "tags": [
          "External Catalogs"
        ],
        "security": [
          {
            "basicAuth": []
          }
        ],
        "parameters": [
          {
            "name": "validOnUid",
            "in": "query",
            "required": false,
            "description": "If supplied, the manifest is replaced only when its current uid equals this value; otherwise the request fails with 400. Must be a non-negative integer.\n",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ManifestInput"
              },
              "example": {
                "my-catalog": {
                  "param1": "value1"
                },
                "other-catalog": {}
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The new manifest, with a server-assigned uid and each catalog's rev set to that uid.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CatalogList"
                },
                "example": {
                  "uid": 5,
                  "my-catalog": {
                    "rev": 5,
                    "param1": "value1"
                  },
                  "other-catalog": {
                    "rev": 5
                  }
                }
              }
            }
          },
          "400": {
            "description": "The request body is not a valid JSON object; a catalog name is invalid (empty, too long, contains invalid characters, or is the reserved name `uid`); a catalog value is not a JSON object; the number of catalogs exceeds the limit; no query node is available; one or more catalogs failed query service validation; `validOnUid` is not a valid integer; or `validOnUid` does not match the current manifest uid.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ManifestError"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      },
      "post": {
        "summary": "Create a new external catalog",
        "operationId": "createExternalCatalog",
        "tags": [
          "External Catalogs"
        ],
        "security": [
          {
            "basicAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CatalogInput"
              },
              "example": {
                "name": "my-catalog"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The created external catalog.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Catalog"
                },
                "example": {
                  "rev": 1
                }
              }
            }
          },
          "400": {
            "description": "Invalid input (name is missing, empty, too long, or contains invalid characters), no query node available, or maximum catalog limit reached.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "409": {
            "description": "A catalog with the given name already exists.\n",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                },
                "example": "External catalog 'my-catalog' already exists"
              }
            }
          }
        }
      }
    },
    "/pools/default/externalCatalogs/{name}": {
      "parameters": [
        {
          "$ref": "#/components/parameters/CatalogName"
        }
      ],
      "get": {
        "summary": "Get an external catalog by name",
        "operationId": "getExternalCatalog",
        "tags": [
          "External Catalogs"
        ],
        "security": [
          {
            "basicAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "The requested external catalog.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Catalog"
                },
                "example": {
                  "rev": 1
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "put": {
        "summary": "Modify (replace) an external catalog",
        "operationId": "replaceExternalCatalog",
        "tags": [
          "External Catalogs"
        ],
        "security": [
          {
            "basicAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CatalogUpdateInput"
              },
              "example": {
                "rev": 1,
                "param1": "value1"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The updated external catalog.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Catalog"
                },
                "example": {
                  "rev": 2
                }
              }
            }
          },
          "400": {
            "description": "Invalid input or no query node available.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/RevMismatch"
          }
        }
      },
      "patch": {
        "summary": "Modify (update) an external catalog",
        "operationId": "updateExternalCatalog",
        "tags": [
          "External Catalogs"
        ],
        "security": [
          {
            "basicAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CatalogUpdateInput"
              },
              "example": {
                "rev": 2,
                "param1": "value1"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The updated external catalog.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Catalog"
                },
                "example": {
                  "rev": 3
                }
              }
            }
          },
          "400": {
            "description": "Invalid input or no query node available.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/RevMismatch"
          }
        }
      },
      "delete": {
        "summary": "Delete an external catalog",
        "operationId": "deleteExternalCatalog",
        "tags": [
          "External Catalogs"
        ],
        "security": [
          {
            "basicAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Catalog deleted successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {}
                },
                "example": []
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic authentication using Couchbase Server credentials. Requires the external_catalog read permission for GET requests and the external_catalog write permission for POST, PUT, and DELETE requests.\n"
      }
    },
    "parameters": {
      "CatalogName": {
        "name": "name",
        "in": "path",
        "required": true,
        "description": "The unique name of the external catalog.\n",
        "schema": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "pattern": "^[a-zA-Z0-9_\\-\\.]+$"
        }
      }
    },
    "schemas": {
      "Catalog": {
        "type": "object",
        "required": [
          "rev"
        ],
        "properties": {
          "rev": {
            "type": "integer",
            "description": "The revision of this catalog, set to the manifest uid at the time of the last mutation.\n",
            "example": 1
          }
        },
        "additionalProperties": {
          "type": "string"
        },
        "description": "A catalog object containing a rev and service-validated parameters. The name is not included in the response body; it is either the key in the list response or part of the URL path.\n"
      },
      "CatalogList": {
        "type": "object",
        "required": [
          "uid"
        ],
        "properties": {
          "uid": {
            "type": "integer",
            "description": "The manifest uid, incremented on every mutation to external catalogs.\n",
            "example": 2
          }
        },
        "additionalProperties": {
          "$ref": "#/components/schemas/Catalog"
        },
        "description": "An object with a uid field and additional properties keyed by catalog name, each being a Catalog object.\n"
      },
      "CatalogUpdateInput": {
        "type": "object",
        "description": "Input for updating a catalog. The name must not be included; it is taken from the URL path. An optional rev may be provided for compare-and-swap semantics.\n",
        "properties": {
          "rev": {
            "type": "integer",
            "description": "Optional. If provided, the update will only succeed if the current revision of the catalog matches this value. If not provided, the update proceeds unconditionally.\n"
          }
        },
        "additionalProperties": {
          "type": "string"
        }
      },
      "CatalogInput": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "The unique name for the external catalog. Must contain only alphanumeric characters, underscores, hyphens, and dots.\n",
            "minLength": 1,
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9_\\-\\.]+$",
            "example": "my-catalog"
          }
        }
      },
      "ManifestInput": {
        "type": "object",
        "description": "A map of catalog names to their service parameters. Each key is a catalog name (1–256 characters, matching `^[0-9A-Za-z_%\\-]+$`). The reserved name `uid` is not allowed. Each value must be a JSON object whose properties are passed to the query service for validation.\n",
        "additionalProperties": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "ManifestError": {
        "description": "Error response for PUT manifest. The `errors` field is either an array (one object per catalog entry, for name-validation failures) or an object keyed by catalog name (for query-service validation failures on a specific catalog).\n",
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "errors": {
                "type": "array",
                "description": "Per-entry name validation errors. Each element corresponds to one catalog entry in the request; entries without errors are empty objects.\n",
                "items": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "example": [
                  {"key": "Can only contain characters A-Z, a-z, 0-9 and the following symbols _ - %"},
                  {}
                ]
              }
            }
          },
          {
            "type": "object",
            "properties": {
              "errors": {
                "type": "object",
                "description": "Per-catalog query-service validation errors, keyed by catalog name.\n",
                "additionalProperties": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "example": {
                  "my-catalog": {
                    "param1": "Unsupported parameter"
                  }
                }
              }
            }
          }
        ]
      },
      "Error": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "A map of field names to error messages.\n"
          }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid credentials.\n"
      },
      "Forbidden": {
        "description": "The authenticated user does not have the required permissions.\n"
      },
      "NotFound": {
        "description": "The requested external catalog was not found.\n",
        "content": {
          "text/plain": {
            "schema": {
              "type": "string"
            },
            "example": "Requested resource not found.\r\n"
          }
        }
      },
      "NoQueryNode": {
        "description": "No query node is available to validate the catalog configuration.\n",
        "content": {
          "application/json": {
            "schema": {
              "type": "string"
            },
            "example": "Must have a query node to configure an external catalog"
          }
        }
      },
      "RevMismatch": {
        "description": "Revision mismatch. The catalog has been modified since it was last read.\n",
        "content": {
          "application/json": {
            "schema": {
              "type": "string"
            },
            "example": "Revision mismatch. The catalog has been modified since it was last read."
          }
        }
      }
    }
  }
}
